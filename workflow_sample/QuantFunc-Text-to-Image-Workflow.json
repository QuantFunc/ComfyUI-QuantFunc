ll}],"outputs":[{"localized_name":"pipeline","name":"pipeline","type":"QUANTFUNC_PIPELINE","links":null}],"properties":{"Node name for S&R":"QuantFuncLoRALoader"},"widgets_values":["",1]},{"id":17,"type":"QuantFuncGenerate","pos":[1191.3648169161618,1317.723598643766],"size":[624.669130803371,341.7789348129254],"flags":{},"order":13,"mode":0,"inputs":[{"localized_name":"pipeline","name":"pipeline","type":"QUANTFUNC_PIPELINE","link":10},{"localized_name":"ref_images","name":"ref_images","shape":7,"type":"QUANTFUNC_IMAGE_LIST","link":null},{"localized_name":"prompt","name":"prompt","type":"STRING","widget":{"name":"prompt"},"link":null},{"localized_name":"width","name":"width","type":"INT","widget":{"name":"width"},"link":null},{"localized_name":"height","name":"height","type":"INT","widget":{"name":"height"},"link":null},{"localized_name":"steps","name":"steps","type":"INT","widget":{"name":"steps"},"link":null},{"localized_name":"seed","name":"seed","type":"INT","widget":{"name":"seed"},"link":null},{"localized_name":"guidance_scale","name":"guidance_scale","type":"FLOAT","widget":{"name":"guidance_scale"},"link":null},{"localized_name":"negative_prompt","name":"negative_prompt","shape":7,"type":"STRING","widget":{"name":"negative_prompt"},"link":null},{"localized_name":"true_cfg_scale","name":"true_cfg_scale","shape":7,"type":"FLOAT","widget":{"name":"true_cfg_scale"},"link":null}],"outputs":[{"localized_name":"image","name":"image","type":"IMAGE","links":[9]}],"properties":{"Node name for S&R":"QuantFuncGenerate"},"widgets_values":["图一女生穿上图二T恤以及图三橙色外套，双手捧着鲜花",960,1536,4,14683112851404,"randomize",0,"",1]},{"id":16,"type":"PreviewImage","pos":[838.9913325147103,1718.3819572947616],"size":[978.9963021672811,321.815912129244],"flags":{},"order":14,"mode":0,"inputs":[{"localized_name":"图像","name":"images","type":"IMAGE","link":9}],"outputs":[],"properties":{"Node name for S&R":"PreviewImage"},"widgets_values":[]},{"id":14,"type":"Note","pos":[-514.2147135040186,1249.97788099821],"size":[418.3823240037274,349.01475591939555],"flags":{},"order":4,"mode":0,"inputs":[],"outputs":[],"title":"使用前阅","properties":{},"widgets_values":["本工作流专用于对 qwen-image / z-image（文生图）系列 Transformer 进行实时量化运行。注意：此场景下不会导出模型，通常用于测试模型与 LoRA 的整合效果。使用前需配置以下参数：\n\n@model_dir：diffusers 格式的模型路径。\n\n@transformer_path：若使用 lighting 模型，此项留空；若使用 svdq 模型，需填入预量化 Transformer 权重路径，例如 path/to/transformer/qwen-image-2511-50x-above-lighting-4steps.safetensors。\n\n@model_backend：必须与当前 Transformer 的模型类型严格对应，可选值为 svdq 或 lighting。\n\n@precision_config（仅 lighting）：需额外指定精度配置文件路径，用于逐层设定精度，具体填写方式请参考官网。\n\n#LoRA 使用说明#\n\n@svdq 模式下使用 LoRA 时，必须添加 LoRA Config 节点，用于控制新 LoRA 与 svdq 中已有 LoRA 的组合方式。推荐使用 ROP 算法——这是我们的创新算法，可先找到多个 LoRA 之间通用的 rank，再以能量损失最小为目标进行截断。\n\n@lighting 模式下使用 LoRA 时，无需添加任何 Config 节点，lighting 会直接将 LoRA 权重与模型权重相加融合。"],"color":"#432","bgcolor":"#653","shape":"round"},{"id":15,"type":"Note","pos":[-510.92667419895076,1653.8320265698392],"size":[415.64032551222726,425.7171689885558],"flags":{},"order":3,"mode":0,"inputs":[],"outputs":[],"title":"Readme","properties":{},"widgets_values":["This workflow is designed for real-time quantization and execution of qwen-image / z-image (text-to-image) series Transformer models. Note: no model will be exported in this mode. It is typically used for testing the integration effects between models and LoRA. The following parameters must be configured:\n\n@model_dir: Path to the model in diffusers format.\ntransformer_path: Leave empty if using a lighting model. If using svdq, provide the path to the pre-quantized Transformer weight file, e.g. path/to/transformer/qwen-image-2511-50x-above-lighting-4steps.safetensors.\n\n@model_backend: Must strictly match the model type of the Transformer being used. Valid options are svdq or lighting.\n\n@precision_config (lighting only): An additional precision config file path is required to specify the precision of each layer. Please refer to the official documentation for details.\n\n#LoRA Usage Notes#\n\n#In svdq mode, a LoRA Config node must be attached to control how the new LoRA combines with the existing LoRA inside svdq. We recommend using the ROP algorithm — our proprietary innovation that first identifies the shared rank across multiple LoRAs, then truncates based on minimum energy loss.\n\n#In lighting mode, no Config node is needed. Lighting directly merges LoRA weights into the model weights by addition."],"color":"#432","bgcolor":"#653","shape":"round"}],"links":[[1,1,0,2,0,"QUANTFUNC_PIPELINE"],[2,2,0,3,0,"IMAGE"],[9,17,0,16,0,"IMAGE"],[10,21,0,17,0,"QUANTFUNC_PIPELINE"],[12,23,0,18,0,"QUANTFUNC_PIPELINE"],[13,19,0,20,0,"QUANTFUNC_PIPELINE"],[14,20,0,21,0,"QUANTFUNC_PIPELINE"],[15,18,0,22,0,"QUANTFUNC_PIPELINE"]],"groups":[{"id":4,"title":"WorkFlow for Qwen-Edit-Series prequant models copy me to your workspace before using it","bounding":[-52.349094456879335,145.82096589818008,1261.4901361918578,885.6057902077864],"color":"#A88","font_size":24,"flags":{}},{"id":7,"title":"WorkFlow for Qwen-Edit-Series run time quant, copy me to your workspace before using it","bounding":[-71.94738935034228,1216.120398011546,1939.767624537425,868.741368625575],"color":"#3f789e","font_size":24,"flags":{}},{"id":5,"title":"Lora config for lighting","bounding":[848.5399464321658,1289.0258808722035,315.1740505509151,321.883150488547],"color":"#3f789e","font_size":24,"flags":{}},{"id":6,"title":"Lora config for svdq","bounding":[-36.74521727294697,1630.5641167046215,845.9246098641829,171.94016397196947],"color":"#a1309b","font_size":24,"flags":{}}],"config":{},"extra":{"workflowRendererVersion":"LG","ds":{"scale":0.99829738850536,"offset":[1119.916820057534,-1358.5964528377242]}},"version":0.4}